# VULNERA — git ignore rules
# Keeps code + YAML configs; excludes data, weights, caches, and local runs.

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.env
.env.*
!.env.example
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.cover

# --- Node / frontend ---
node_modules/
09_WEB/front_end/dist/
*.local

# --- IDE / OS ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# --- Datasets (download separately; see README) ---
01_Data_Processing/data/raw/**
01_Data_Processing/data/interim/**
01_Data_Processing/data/processed/**
01_Data_Processing/data/embeddings/**
01_Data_Processing/Adaptive_Dataset/*.parquet
!01_Data_Processing/data/raw/.gitkeep
!01_Data_Processing/data/interim/.gitkeep
!01_Data_Processing/data/processed/.gitkeep
!01_Data_Processing/data/embeddings/.gitkeep

# --- Reports (regenerated by pipeline) ---
01_Data_Processing/reports/**
!01_Data_Processing/reports/.gitkeep

# --- ML model weights ---
02_ML_Model/graphcodebert-base/**/*.bin
02_ML_Model/graphcodebert-base/**/*.safetensors
02_ML_Model/**/.cache/

# --- Trained joblib artifacts (retrain via pipeline) ---
03_TREE/**/final/*.joblib
03_TREE/results/**
04_META/**/selected/*.joblib
04_META/results/**
05_SCORE/**/selected/*.joblib
05_SCORE/**/selected/*.json
05_SCORE/results/**
06_AGGREGATOR/artifacts/**
06_AGGREGATOR/results/**
!06_AGGREGATOR/results/baseline_transfer/
!06_AGGREGATOR/results/baseline_transfer/**

# Keep selected deployment JSON if you want to ship a frozen threshold (optional):
# !05_SCORE/window_stack/selected/calibrated_deployment.json

# --- LLM weights ---
08_LLM/models/**/*
!08_LLM/models/.gitkeep
08_LLM/**/.cache/

# --- XAI generated artifacts ---
07_XAI/artifacts/**

# --- Web scan outputs (local dev) ---
09_WEB/scans/*.json
!09_WEB/scans/.gitkeep

# --- Logs & temp ---
*.log
*.tmp
*.temp
.cache/
